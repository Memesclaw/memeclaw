{
  "name": "memeclaw",
  "version": "1.2.0",
  "description": "🦞 MemeClaw - The AI assistant that learns any MEME skill. Tax rewards for skill contributors.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "memeclaw": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node scripts/start-gateway.js",
    "dev": "tsx watch src/index.ts",
    "gateway": "node scripts/start-gateway.js",
    "gateway:dev": "tsx src/gateway/index.ts",
    "gateway:prod": "node dist/gateway/index.js",
    "agent": "tsx src/agent/index.ts",
    "onboard": "node dist/commands/index.js init",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:preview": "cd frontend && npm run preview",
    "install:all": "npm install && cd frontend && npm install",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "keywords": [
    "meme",
    "ai",
    "assistant",
    "crypto",
    "tokenomics",
    "memecoin",
    "openclaw"
  ],
  "author": "MemeClaw Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@clack/prompts": "^1.1.0",
    "axios": "^1.6.5",
    "better-sqlite3": "^11.0.0",
    "chalk": "4.1.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "16.4.5",
    "ethers": "^6.9.2",
    "express": "^4.18.2",
    "grammy": "^1.30.0",
    "inquirer": "^8.2.6",
    "minimist": "1.0.0",
    "openai": "^4.24.0",
    "ora": "^5.4.1",
    "picocolors": "^1.1.1",
    "socks-proxy-agent": "^8.0.5",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.11",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/memesclaw/memeclaw"
  }
}
